# === UPSC Clipper Backend Configuration ===

# Internal auth token — set this to a strong random string.
# The Chrome extension sends this in the X-App-Local-Token header.
APP_LOCAL_TOKEN=change-me-to-a-strong-secret

# Notion integration token (from https://developers.notion.com/)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Per-paper Notion Parent IDs
# Use EITHER page IDs OR database IDs — page IDs take precedence.
#
# OPTION A: Standard Notion Pages (recommended)
#   Create one page each for GS1–GS4, Ethics, Optional.
#   The extension will create a sub-page inside each for every clipped article.
NOTION_PAGE_GS1=
NOTION_PAGE_GS2=
NOTION_PAGE_GS3=
NOTION_PAGE_GS4=
NOTION_PAGE_ETHICS=
NOTION_PAGE_OPTIONAL=

# OPTION B: Notion Database IDs (advanced — use if you prefer table rows)
#   Leave blank if using page IDs above.
NOTION_DB_GS1=
NOTION_DB_GS2=
NOTION_DB_GS3=
NOTION_DB_GS4=
NOTION_DB_ETHICS=
NOTION_DB_OPTIONAL=

# Optional subject name (e.g. "Geography", "History", "Sociology", etc.)
OPTIONAL_SUBJECT_NAME=

# Local database path (relative to backend/ or absolute)
DB_PATH=./data/clipper.db

# SQLCipher encryption (optional — requires native sqlcipher libs)
USE_SQLCIPHER=false
SQLCIPHER_KEY=

# Server
HOST=127.0.0.1
PORT=8000
